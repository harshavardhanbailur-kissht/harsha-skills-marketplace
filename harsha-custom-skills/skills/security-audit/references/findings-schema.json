{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://claude.ai/security-audit/findings-schema.json",
  "title": "Security Audit Findings Schema",
  "description": "JSON Schema for security audit findings used by coordinator.md and generate-report.py",
  "type": "object",
  "required": ["project", "audit_date", "risk_score", "findings", "summary"],
  "properties": {
    "project": {
      "type": "string",
      "description": "Name of the audited project or repository"
    },
    "audit_date": {
      "type": "string",
      "format": "date",
      "description": "Date of the audit in YYYY-MM-DD format"
    },
    "risk_score": {
      "type": "integer",
      "minimum": 0,
      "maximum": 100,
      "description": "Overall risk score calculated as: Critical*25 + High*10 + Medium*3 + Low*1, capped at 100"
    },
    "findings": {
      "type": "array",
      "description": "List of all security findings",
      "items": {
        "$ref": "#/$defs/finding"
      }
    },
    "summary": {
      "type": "object",
      "description": "Count of findings by severity",
      "required": ["critical", "high", "medium", "low", "info"],
      "properties": {
        "critical": {
          "type": "integer",
          "minimum": 0
        },
        "high": {
          "type": "integer",
          "minimum": 0
        },
        "medium": {
          "type": "integer",
          "minimum": 0
        },
        "low": {
          "type": "integer",
          "minimum": 0
        },
        "info": {
          "type": "integer",
          "minimum": 0
        }
      }
    },
    "metadata": {
      "type": "object",
      "description": "Optional metadata about the audit",
      "properties": {
        "skill_version": {
          "type": "string"
        },
        "frameworks_detected": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "languages_detected": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "files_scanned": {
          "type": "integer",
          "minimum": 0
        },
        "scan_duration_seconds": {
          "type": "number",
          "minimum": 0
        }
      }
    }
  },
  "$defs": {
    "finding": {
      "type": "object",
      "required": [
        "id",
        "title",
        "severity",
        "cvss",
        "cwe",
        "owasp",
        "domain",
        "location",
        "evidence",
        "impact",
        "fix",
        "verification",
        "checklist_status"
      ],
      "properties": {
        "id": {
          "type": "string",
          "pattern": "^FINDING-[0-9]{3}$",
          "description": "Unique identifier in FINDING-NNN format"
        },
        "title": {
          "type": "string",
          "minLength": 5,
          "maxLength": 100,
          "description": "Brief description of the vulnerability"
        },
        "severity": {
          "type": "string",
          "enum": ["critical", "high", "medium", "low", "info"],
          "description": "Severity level based on CVSS score ranges"
        },
        "cvss": {
          "type": "number",
          "minimum": 0.0,
          "maximum": 10.0,
          "description": "CVSS 3.1 base score"
        },
        "cwe": {
          "type": "string",
          "pattern": "^CWE-[0-9]+$",
          "description": "Common Weakness Enumeration identifier"
        },
        "owasp": {
          "type": "string",
          "pattern": "^A[0-9]{2}:2021-.+$",
          "description": "OWASP Top 10 2021 category (e.g., A03:2021-Injection)"
        },
        "domain": {
          "type": "string",
          "enum": [
            "injection",
            "xss-csrf",
            "auth-session",
            "access-control",
            "crypto-data",
            "secrets",
            "dependency",
            "config-headers",
            "logging-monitoring",
            "error-handling",
            "concurrency",
            "api-endpoint",
            "input-output",
            "business-logic"
          ],
          "description": "Security domain this finding belongs to"
        },
        "location": {
          "type": "string",
          "pattern": "^.+:[0-9]+$",
          "description": "File path and line number (e.g., src/api/users.js:47)"
        },
        "evidence": {
          "type": "string",
          "minLength": 1,
          "description": "Code snippet demonstrating the vulnerability"
        },
        "impact": {
          "type": "string",
          "minLength": 10,
          "description": "Description of potential damage if exploited"
        },
        "fix": {
          "type": "string",
          "minLength": 1,
          "description": "Diff-formatted fix (lines starting with - for removed, + for added)"
        },
        "verification": {
          "type": "string",
          "minLength": 10,
          "description": "Steps to verify the fix works without breaking functionality"
        },
        "checklist_status": {
          "type": "string",
          "enum": ["all_pass", "requires_review", "pending"],
          "description": "Status of the 10-point non-invasive checklist verification"
        },
        "checklist_notes": {
          "type": "string",
          "description": "Explanation when checklist_status is requires_review"
        },
        "duplicate_count": {
          "type": "integer",
          "minimum": 1,
          "description": "Number of duplicate findings merged into this one"
        },
        "domains": {
          "type": "array",
          "items": {
            "type": "string"
          },
          "description": "List of domains that found this issue (for merged duplicates)"
        }
      }
    },
    "severity_thresholds": {
      "description": "CVSS score thresholds for severity levels",
      "type": "object",
      "properties": {
        "critical": {
          "const": "9.0-10.0"
        },
        "high": {
          "const": "7.0-8.9"
        },
        "medium": {
          "const": "4.0-6.9"
        },
        "low": {
          "const": "0.1-3.9"
        },
        "info": {
          "const": "0"
        }
      }
    }
  },
  "examples": [
    {
      "project": "example-api",
      "audit_date": "2024-01-15",
      "risk_score": 63,
      "findings": [
        {
          "id": "FINDING-001",
          "title": "SQL Injection in user search",
          "severity": "critical",
          "cvss": 9.8,
          "cwe": "CWE-89",
          "owasp": "A03:2021-Injection",
          "domain": "injection",
          "location": "src/api/users.js:47",
          "evidence": "const query = `SELECT * FROM users WHERE id = ${req.params.id}`;",
          "impact": "Full database access, data exfiltration, potential RCE",
          "fix": "- const query = `SELECT * FROM users WHERE id = ${req.params.id}`;\n+ const query = 'SELECT * FROM users WHERE id = ?';\n+ connection.query(query, [req.params.id]);",
          "verification": "1. Run existing tests\n2. Verify query returns same data\n3. Test SQL injection payload returns 400",
          "checklist_status": "all_pass",
          "checklist_notes": ""
        }
      ],
      "summary": {
        "critical": 1,
        "high": 2,
        "medium": 5,
        "low": 3,
        "info": 1
      }
    }
  ]
}
