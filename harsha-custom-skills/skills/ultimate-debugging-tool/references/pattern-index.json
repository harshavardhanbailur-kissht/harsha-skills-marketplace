      ],
      "reference_file": "gsap-bugs.md",
      "safe_fix_pattern": "Use useGSAP hook OR manually call context.revert() on unmount",
      "unsafe_patterns": [
        "context without cleanup",
        "missing revert call"
      ]
    },
    {
      "id": "G-002",
      "title": "ScrollTrigger Not Refreshed After DOM Change",
      "framework": "GSAP",
      "min_version": "3.12.0",
      "max_version": null,
      "severity": "high",
      "category": "animation",
      "symptoms": [
        "scroll animations trigger at wrong position",
        "cached dimensions used",
        "animations skip"
      ],
      "detection_signals": [
        "ScrollTrigger without refresh",
        "DOM height changes",
        "state changes"
      ],
      "reference_file": "gsap-bugs.md",
      "safe_fix_pattern": "Call ScrollTrigger.refresh() in useEffect after DOM changes",
      "unsafe_patterns": [
        "refresh called too early",
        "no refresh on DOM change"
      ]
    },
    {
      "id": "G-003",
      "title": "Lenis + ScrollTrigger Desync",
      "framework": "GSAP",
      "min_version": "3.12.0",
      "max_version": null,
      "severity": "high",
      "category": "animation",
      "symptoms": [
        "scroll animations are jerky",
        "scrollbar doesn't match animation",
        "animations skip"
      ],
      "detection_signals": [
        "Lenis and ScrollTrigger together",
        "no sync code",
        "lagSmoothing not disabled"
      ],
      "reference_file": "gsap-bugs.md",
      "safe_fix_pattern": "Connect Lenis to ScrollTrigger.update + disable lagSmoothing",
      "unsafe_patterns": [
        "both libraries without syncing",
        "different scroll sources"
      ]
    },
    {
      "id": "G-004",
      "title": "Conflicting Tweens",
      "framework": "GSAP",
      "min_version": "3.12.0",
      "max_version": null,
      "severity": "medium",
      "category": "animation",
      "symptoms": [
        "two animations fight each other",
        "values jump or flicker",
        "conflicting properties"
      ],
      "detection_signals": [
        "multiple gsap.to() same property",
        "no killTweensOf",
        "no overwrite"
      ],
      "reference_file": "gsap-bugs.md",
      "safe_fix_pattern": "Kill tweens with killTweensOf() OR use overwrite: 'auto' OR use timeline",
      "unsafe_patterns": [
        "overlapping tweens",
        "no conflict resolution"
      ]
    },
    {
      "id": "TS-001",
      "title": "any Type Masking Real Bugs",
      "framework": "TypeScript",
      "min_version": "5.0",
      "max_version": null,
      "severity": "high",
      "category": "types",
      "symptoms": [
        "type errors not caught until runtime",
        "refactoring breaks code silently",
        "no type checking"
      ],
      "detection_signals": [
        "any type usage",
        "as any casts",
        "any in generics"
      ],
      "reference_file": "typescript-bugs.md",
      "safe_fix_pattern": "Define proper types OR use type guards OR enable stricter checks",
      "unsafe_patterns": [
        "any type everywhere",
        "casting with as any",
        "avoiding type definitions"
      ]
    },
    {
      "id": "TS-002",
      "title": "Missing Strict Null Checks",
      "framework": "TypeScript",
      "min_version": "5.0",
      "max_version": null,
      "severity": "high",
      "category": "types",
      "symptoms": [
        "Cannot read property of undefined errors in production",
        "null reference errors"
      ],
      "detection_signals": [
        "strictNullChecks disabled",
        "no optional chaining",
        "null/undefined not handled"
      ],
      "reference_file": "typescript-bugs.md",
      "safe_fix_pattern": "Enable strictNullChecks in tsconfig OR use optional chaining (?.) and nullish coalescing (??)",
      "unsafe_patterns": [
        "strictNullChecks false",
        "unsafe non-null assertions !",
        "ignoring null possibility"
      ]
    },
    {
      "id": "TS-003",
      "title": "Incorrect Type Narrowing",
      "framework": "TypeScript",
      "min_version": "5.0",
      "max_version": null,
      "severity": "medium",
      "category": "types",
      "symptoms": [
        "type logic errors",
        "wrong code path executed",
        "type confusion"
      ],
      "detection_signals": [
        "broken type guards",
        "union type confusion",
        "missing discriminators"
      ],
      "reference_file": "typescript-bugs.md",
      "safe_fix_pattern": "Use strong type guards OR discriminated unions OR switch statements",
      "unsafe_patterns": [
        "incorrect typeof checks",
        "type assertions instead of narrowing",
        "optional chaining vs guards"
      ]
    }
  ]
}